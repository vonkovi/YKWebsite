---
interface Props {
  zone: 'portfolio' | 'blog';
  pageName: string;
}
const { zone, pageName } = Astro.props;
---

<header class="border-b border-yk-dark px-6 py-4 flex items-center justify-between">
  <!-- Branding -->
  <a href="/" class="font-serif text-xl tracking-wide text-yk-dark">YVONKIM</a>

  <!-- Social Icons -->
  <div class="flex items-center gap-3">
    <!-- GitHub -->
    <a href="https://github.com/yvonkim" target="_blank" rel="noopener"
       class="border border-yk-dark p-1.5 hover:bg-yk-dark hover:text-yk-white transition-colors">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
      </svg>
    </a>

    <!-- LinkedIn -->
    <a href="https://linkedin.com/in/yvonkim" target="_blank" rel="noopener"
       class="border border-yk-dark p-1.5 hover:bg-yk-dark hover:text-yk-white transition-colors">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>

    <!-- Email (copy to clipboard) -->
    <button id="email-btn"
            class="border border-yk-dark p-1.5 hover:bg-yk-dark hover:text-yk-white transition-colors cursor-pointer"
            title="Copy email">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
      </svg>
    </button>

    <!-- CV Download -->
    <a href="/resume.pdf" download
       class="border border-yk-dark p-1.5 hover:bg-yk-dark hover:text-yk-white transition-colors"
       title="Download CV">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="12" y1="18" x2="12" y2="12"/>
        <polyline points="9 15 12 18 15 15"/>
      </svg>
    </a>

    <!-- Discord -->
    <a href="https://discord.com/users/yvonkim" target="_blank" rel="noopener"
       class="border border-yk-dark p-1.5 hover:bg-yk-dark hover:text-yk-white transition-colors">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
      </svg>
    </a>
  </div>

  <!-- Page Name -->
  <span class="font-sans text-sm tracking-widest text-yk-dark uppercase">{pageName}</span>

  <!-- Nav Button -->
  {zone === 'portfolio'
    ? <a href="/blog" class="font-sans text-sm border border-yk-dark px-3 py-1 hover:bg-yk-dark hover:text-yk-white transition-colors">personal blog →</a>
    : <a href="/" class="font-sans text-sm border border-yk-dark px-3 py-1 hover:bg-yk-dark hover:text-yk-white transition-colors">← portfolio</a>
  }
</header>

<script>
  document.getElementById('email-btn')?.addEventListener('click', () => {
    navigator.clipboard.writeText('ykim336@ucr.edu');
  });
</script>
